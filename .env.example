# ============================================================
# THE ARCHIVIST METHOD — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# Add all of these to your Vercel project dashboard under
# Settings → Environment Variables.
# ============================================================

# ---------------------------
# Supabase (server-side)
# Used by: Express server (auth, purchases, user data)
# ---------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---------------------------
# Supabase (client-side / Vite)
# Must be prefixed VITE_ so Vite exposes them to the browser bundle.
# Used by: React frontend (Supabase JS client)
# ---------------------------
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ---------------------------
# Stripe
# Used by: Express server (checkout, webhook verification)
# Switch to sk_live_* / pk_live_* when going to production.
# ---------------------------
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ---------------------------
# Auth
# Used by: Express server (JWT signing for magic links)
# Generate with: openssl rand -base64 64
# ---------------------------
JWT_SECRET=your-strong-random-string-here

# ---------------------------
# Email (Resend)
# Used by: Express server (sending magic link emails)
# ---------------------------
RESEND_API_KEY=re_your_resend_api_key

# ---------------------------
# AI (Anthropic / Claude API)
# Used by: Express server (Archivist Chatbot endpoint)
# ---------------------------
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# ---------------------------
# App
# Used by: Express server (constructing magic link URLs)
# Set to your Vercel deployment URL or custom domain.
# ---------------------------
APP_URL=https://thearchivistmethod.com
PORTAL_BASE_URL=https://thearchivistmethod.com

# ---------------------------
# Test user allowlist
# Any email listed here is auto-provisioned into test_users + quiz_users on
# first login attempt (accessLevel=archive, godMode=true, primaryPattern=
# disappearing by default). Survives database resets.
#
# ADMIN_EMAIL accepts a single email. TEST_USER_EMAILS accepts a comma-separated
# list. Optional: TEST_USER_PRIMARY_PATTERN, TEST_USER_NAME override the defaults
# applied at provision time.
# ---------------------------
ADMIN_EMAIL=houstoninvestments@gmail.com
# TEST_USER_EMAILS=other@example.com,another@example.com
# TEST_USER_PRIMARY_PATTERN=disappearing
# TEST_USER_NAME=Aaron Houston
