# ============================================================
# THE ARCHIVIST METHOD — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# Add all of these to your Vercel project dashboard under
# Settings → Environment Variables.
# ============================================================

# ---------------------------
# Postgres (Drizzle ORM)
# Used by: Express server (drizzle client, migrations via `npm run db:push`).
# Typically the Supabase connection pooler URL or a direct Postgres URL.
# ---------------------------
DATABASE_URL=postgresql://user:password@host:5432/archivist

# ---------------------------
# Admin console
# ADMIN_PASSWORD: shared password for the /admin login form.
# SESSION_SECRET: Express session signing secret for admin sessions.
#   Generate with: openssl rand -base64 32
# ---------------------------
ADMIN_PASSWORD=replace-with-strong-admin-password
SESSION_SECRET=replace-with-openssl-rand-base64-32

# ---------------------------
# Smoke test user
# Email used by automated portal smoke tests (seeded into test_users).
# ---------------------------
TEST_USER_EMAIL=qa+archivist@example.com

# ---------------------------
# Supabase (server-side)
# Used by: Express server (auth, purchases, user data)
# ---------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---------------------------
# Supabase (client-side / Vite)
# Must be prefixed VITE_ so Vite exposes them to the browser bundle.
# Used by: React frontend (Supabase JS client)
# ---------------------------
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ---------------------------
# Stripe
# Used by: Express server (checkout, webhook verification) and the browser
# bundle (VITE_STRIPE_PUBLISHABLE_KEY loads stripe-js in src/lib/stripe.ts).
# Switch to sk_live_* / pk_live_* when going to production.
# ---------------------------
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key

# ---------------------------
# Auth
# Used by: Express server (JWT signing for magic links)
# Generate with: openssl rand -base64 64
# ---------------------------
JWT_SECRET=your-strong-random-string-here

# ---------------------------
# Email (Resend)
# Used by: Express server (magic link emails + the 7-email Crash Course
# drip and buyer sequences scheduled in the email_queue table).
# RESEND_FROM_EMAIL must be a verified sender on the Resend domain.
# ---------------------------
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=The Archivist <archivist@thearchivistmethod.com>

# ---------------------------
# Cron secret
# Used by: /api/cron/email-queue. Vercel calls that endpoint with
# `Authorization: Bearer $CRON_SECRET`. Generate with:
#   openssl rand -hex 32
# ---------------------------
CRON_SECRET=your-cron-secret

# ---------------------------
# AI (Anthropic / Claude API)
# Used by: Express server (Archivist Chatbot endpoint)
# ---------------------------
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# ---------------------------
# Voice (ElevenLabs TTS)
# Used by: Express server (/api/portal/voice/speak) for the Pocket Archivist
# voice conversation experience.
# ---------------------------
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_VOICE_ID=busoBrxbSdnsO2rCQwxq

# ---------------------------
# App
# Used by: Express server (constructing magic link URLs)
# Set to your Vercel deployment URL or custom domain.
# ---------------------------
APP_URL=https://thearchivistmethod.com
PORTAL_BASE_URL=https://thearchivistmethod.com

# ---------------------------
# Test user allowlist
# Any email listed here is auto-provisioned into test_users + quiz_users on
# first login attempt (accessLevel=archive, godMode=true, primaryPattern=
# disappearing by default). Survives database resets.
#
# ADMIN_EMAIL accepts a single email. TEST_USER_EMAILS accepts a comma-separated
# list. Optional: TEST_USER_PRIMARY_PATTERN, TEST_USER_NAME override the defaults
# applied at provision time.
# ---------------------------
ADMIN_EMAIL=houstoninvestments@gmail.com
# TEST_USER_EMAILS=other@example.com,another@example.com
# TEST_USER_PRIMARY_PATTERN=disappearing
# TEST_USER_NAME=Aaron Houston
